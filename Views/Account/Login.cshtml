@{
    ViewData["Title"] = "System Login";
}

<div class="container mt-5 pt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg rounded-3 border-0">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h3 class="mb-0">🔐 System Login</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-controller="Account" asp-action="Login" method="post">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Email Address</label>
                            <input type="email" name="email" class="form-control form-control-lg" placeholder="e.g., pathum@student.com" required />
                            <div class="form-text text-muted">Enter any email to auto-register for the demo.</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">I am a...</label>
                            <select name="role" class="form-select form-select-lg">
                                <option value="Student">🎓 Student</option>
                                <option value="Supervisor">👨‍🏫 Supervisor</option>
                            </select>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">Log In</button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
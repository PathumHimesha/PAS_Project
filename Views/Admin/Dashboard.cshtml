@model IEnumerable<PAS_Project.Models.Project>

@{
    ViewData["Title"] = "Module Leader Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4 text-danger fw-bold">👑 Module Leader (Admin) Dashboard</h2>
    <p class="text-muted mb-4">Overview of all project allocations in the system.</p>

    <div class="table-responsive">
        <table class="table table-hover table-bordered shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Project Title</th>
                    <th>Student Name</th>
                    <th>Supervisor Name</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.Title</td>
                        <td>@(item.Student?.Name ?? "Unknown")</td>
                        <td>
                            @if (item.Supervisor != null)
                            {
                                <span class="text-success fw-bold">@item.Supervisor.Name</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Not Assigned</span>
                            }
                        </td>
                        <td>
                            @if (item.Status == PAS_Project.Models.ProjectStatus.Matched)
                            {
                                <span class="badge bg-success px-3 py-2">Matched</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark px-3 py-2">Pending</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@model IEnumerable<PAS_Project.Models.Project>

@{
    ViewData["Title"] = "Supervisor Dashboard";
}

<div class="container mt-5">
    <h2 class="text-primary mb-4">👨‍🏫 Supervisor Dashboard</h2>
    
    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Project Title</th>
                        <th>Research Area</th>
                        <th>Tech Stack</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="fw-bold">@item.Title</td>
                            <td>@item.ResearchArea</td>
                            <td>@item.TechnicalStack</td>
                            <td>
                                @if (item.Status.ToString() == "Pending")
                                {
                                    <span class="badge bg-warning text-dark fs-6">Pending</span>
                                }
                                else
                                {
                                    <span class="badge bg-success fs-6">Matched</span>
                                }
                            </td>
                            <td>
                                @if (item.Status.ToString() == "Pending")
                                {
                                    <form asp-controller="Projects" asp-action="ExpressInterest" method="post">
                                        <input type="hidden" name="projectId" value="@item.ProjectId" />
                                        <input type="hidden" name="supervisorId" value="1" /> <button type="submit" class="btn btn-sm btn-success">Accept Project</button>
                                    </form>
                                }
                                else
                                {
                                    <a asp-controller="Projects" asp-action="MatchDetails" asp-route-id="@item.ProjectId" class="btn btn-sm btn-outline-primary">View Match</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>